{
    "name": "mb4it/moonshine-pages",
    "description": "MoonShine pages and menu package",
    "type": "library",
    "version": "1.0.1",
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "illuminate/contracts": "^12.0",
        "illuminate/database": "^12.0",
        "illuminate/http": "^12.0",
        "illuminate/support": "^12.0",
        "moonshine/ckeditor": "^3.0",
        "moonshine/moonshine": "^4.8"
    },
    "autoload": {
        "psr-4": {
            "MB\\MoonShine\\": "src/"
        },
        "files": [
            "src/Support/helpers.php"
        ]
    },
    "extra": {
        "laravel": {
            "providers": [
                "MB\\MoonShine\\MoonshinePagesServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
