{
    "name": "mb4it/moonshine-pages",
    "description": "MoonShine pages and menu package",
    "type": "library",
    "version": "1.0.3",
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "illuminate/contracts": "^12.0",
        "illuminate/database": "^12.0",
        "illuminate/http": "^12.0",
        "illuminate/support": "^12.0",
        "moonshine/ckeditor": "^3.0",
        "moonshine/moonshine": "^4.8"
    },
    "autoload": {
        "psr-4": {
            "MB\\MoonShine\\": "src/"
        },
        "files": [
            "src/Support/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "MB\\MoonShine\\Tests\\": "tests/"
        }
    },
    "require-dev": {
        "orchestra/testbench": "^10.0",
        "phpunit/phpunit": "^11.5"
    },
    "scripts": {
        "test": "phpunit --configuration phpunit.xml"
    },
    "extra": {
        "laravel": {
            "providers": [
                "MB\\MoonShine\\MoonshinePagesServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
